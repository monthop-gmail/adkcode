# Google AI — choose ONE auth method:

# Option 1: API key (simple) — get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# Option 2: Vertex AI + ADC (no API key needed)
# Run `gcloud auth application-default login` on host first
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model configuration (optional)
# Smart model — used by orchestrator and reviewer (analysis, routing)
# ADKCODE_MODEL_SMART=gemini-2.5-flash
# Fast model — used by coder and tester (speed, execution)
# ADKCODE_MODEL_FAST=gemini-2.0-flash

# Safety & Guardrails (optional)
# Restrict file access to specific directories (comma-separated)
# ADKCODE_ALLOWED_DIRS=/workspace,/home/user/projects
# Enable audit log (JSON lines file)
# ADKCODE_AUDIT_LOG=/var/log/adkcode/audit.jsonl

# Plugins (optional)
# Load only specific plugins (comma-separated). Default: load all.
# ADKCODE_PLUGINS=engineering,data,productivity
# Disable all plugins:
# ADKCODE_PLUGINS=none
