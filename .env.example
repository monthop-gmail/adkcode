# Get your API key from https://aistudio.google.com
GOOGLE_API_KEY=your-api-key-here

# Model configuration (optional)
# Smart model — used by orchestrator and reviewer (analysis, routing)
# ADKCODE_MODEL_SMART=gemini-2.5-flash
# Fast model — used by coder and tester (speed, execution)
# ADKCODE_MODEL_FAST=gemini-2.0-flash

# Safety & Guardrails (optional)
# Restrict file access to specific directories (comma-separated)
# ADKCODE_ALLOWED_DIRS=/workspace,/home/user/projects
# Enable audit log (JSON lines file)
# ADKCODE_AUDIT_LOG=/var/log/adkcode/audit.jsonl
